{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",
    "lib": ["es2023"],
    "types": ["node"],
    "skipLibCheck": true,
    "maxNodeModuleJsDepth": 0,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["scripts/**/*.mjs", "mcp-server/**/*.mjs"],
  "exclude": ["node_modules", "test", "wiki"]
}
