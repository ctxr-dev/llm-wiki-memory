{
  "name": "llm-wiki-memory",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Local LLM-wiki-backed memory for Claude Code: capture, compile, and recall agent memory in a git-versioned local wiki (no RAG, no Docker). Powered by @ctxr/skill-llm-wiki.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ctxr-dev/llm-wiki-memory"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "llm-wiki-memory": "scripts/cli.mjs"
  },
  "exports": {
    ".": "./scripts/lib/wiki-store.mjs",
    "./topology-runtime": "./scripts/lib/topology-runtime.mjs",
    "./path-compiler": "./scripts/lib/path-compiler.mjs"
  },
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "test:e2e": "node --test test/e2e/*.test.mjs",
    "mcp": "node mcp-server/index.mjs"
  },
  "dependencies": {
    "@ctxr/skill-llm-wiki": "^1.4.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@xenova/transformers": "2.17.2",
    "gray-matter": "^4.0.3",
    "yaml": "^2.6.1",
    "zod": "3.25.76"
  }
}
