{
  "name": "llm-wiki-memory",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Local LLM-wiki-backed memory for Claude Code: capture, compile, and recall agent memory in a git-versioned local wiki (no RAG, no Docker). Powered by @ctxr/skill-llm-wiki.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ctxr-dev/llm-wiki-memory"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "llm-wiki-memory": "scripts/cli.mjs"
  },
  "exports": {
    ".": "./scripts/lib/wiki-store.mjs",
    "./topology-runtime": "./scripts/lib/topology-runtime.mjs",
    "./path-compiler": "./scripts/lib/path-compiler.mjs"
  },
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "test:e2e": "cross-env MEMORY_EMBED_BACKEND=lexical node --test test/e2e/*.test.mjs",
    "mcp": "node mcp-server/index.mjs",
    "typecheck": "tsc -p jsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deadcode": "knip",
    "check:size": "find scripts mcp-server -name '*.mjs' -exec wc -l {} + | awk '$2!=\"total\" && $1>300 {print $1\"  \"$2; c++} END{exit c>0?1:0}'",
    "check:comments": "test -z \"$(grep -rnE '^[[:space:]]*//[[:space:]]*[-=*]{3,}|^[[:space:]]*/\\*[[:space:]]*[-=*]{3,}' scripts mcp-server test --include='*.mjs')\"",
    "gates": "npm run typecheck && npx eslint . --max-warnings 0 && npm run format:check && npm run deadcode && npm run check:size && npm run check:comments && npm test && npm run test:e2e"
  },
  "dependencies": {
    "@ctxr/skill-llm-wiki": "^1.4.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@xenova/transformers": "2.17.2",
    "better-sqlite3": "^12.11.1",
    "gray-matter": "^4.0.3",
    "yaml": "^2.6.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.5",
    "globals": "^17.7.0",
    "knip": "^5.88.1",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3"
  }
}
