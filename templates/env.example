# llm-wiki-memory: secrets + provider switches + paths + test seams.
#
# Rendered to ./.llm-wiki-memory/settings/.env by bootstrap.sh — auto-detected
# at install (see bootstrap.sh `--provider` flag), user-editable thereafter.
# Lines are KEY=VALUE; process env overrides file values. To re-detect:
# re-run bootstrap.sh — it preserves any user-edited MEMORY_LLM_PROVIDER line.
#
# THIS FILE ONLY carries the strict subset that genuinely needs shell
# precedence. Application config (consolidate / flush / hook / embed /
# recall / compile / gc / gate / providers) lives in ./settings.yaml —
# see ./.llm-wiki-memory/src/templates/settings.yaml for the schema.
#
# 2026-06-03 v2 breaking change: every NON-strict MEMORY_* env var is
# REMOVED. Setting MEMORY_CONSOLIDATE_COSINE_THRESHOLD or MEMORY_FLUSH_*
# or MEMORY_HOOK_* or MEMORY_EMBED_* or MEMORY_RECALL_* or MEMORY_GC_*
# at the shell is now a SILENT no-op. Move them to ./settings.yaml at the
# matching section. See docs/releases/2026/06/03/v2/update-prompt.md.

# LLM provider for atom extraction (flush), dedup decisions (compile), and
# consolidate's LLM passes. One of:
#   claude              — uses the `claude` CLI on PATH (default for Claude Code)
#   codex               — uses the `codex` CLI on PATH
#   cursor              — uses `cursor-agent` CLI on PATH
#   anthropic           — direct API; needs ANTHROPIC_API_KEY
#   openai              — direct API; needs OPENAI_API_KEY
#   openai-compatible   — local OpenAI-compatible endpoint (ollama, vLLM,
#                         lm-studio, llama.cpp server, litellm proxy); set
#                         MEMORY_LLM_BASE_URL (API key optional for local/RFC1918)
#   mock                — test/dev only; canned response from MEMORY_LLM_MOCK_*
#
# Setting this collapses the YAML providers.chain to a single provider for
# this process. Unset, the YAML chain (or auto-detection) takes over.
MEMORY_LLM_PROVIDER=claude

# Provider-agnostic model override. When set, prepends to the head provider's
# models[] list in settings.yaml. For openai-compatible, set to whatever name
# your local server expects (e.g. "llama3.1:8b-instruct" for ollama).
# MEMORY_LLM_MODEL=

# OpenAI-compatible base URL (overrides https://api.openai.com/v1). When set
# to a localhost / RFC1918 host, OPENAI_API_KEY becomes optional. Examples:
#   MEMORY_LLM_BASE_URL=http://localhost:11434/v1   # ollama default
#   MEMORY_LLM_BASE_URL=http://localhost:8000/v1    # vLLM / lm-studio
# MEMORY_LLM_BASE_URL=

# Per-call CLI / API timeout in milliseconds. Default 120000 (120 s).
# MEMORY_LLM_TIMEOUT_MS=120000

# Provider-specific API keys + model overrides. Honoured by the dispatcher
# when the YAML provider's models list isn't sufficient.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=
# OPENAI_API_KEY=
# OPENAI_MODEL=

# Mock provider seams (test/dev only). One of MOCK_RESPONSE / MOCK_FILE must
# be set when PROVIDER=mock. FAIL_INDICES + FAIL_ERROR inject failures on
# specific mock-call indices for testing the chain's fallback paths.
# MEMORY_LLM_MOCK_RESPONSE='{"action":"skip","reason":"mock"}'
# MEMORY_LLM_MOCK_FILE=/tmp/mock-llm-response.json
# MEMORY_LLM_MOCK_FAIL_INDICES=0,2
# MEMORY_LLM_MOCK_FAIL_ERROR="model_not_found: simulated"

# Deployment paths (defaults are derived from the workspace).
# LLM_WIKI_MEMORY_ROOT=./.llm-wiki-memory/wiki
# MEMORY_EMBED_CACHE=./.llm-wiki-memory/index/embeddings.json
# MEMORY_EMBED_CACHE_DIR=./.llm-wiki-memory/index/models   # transformers.js model cache
# MEMORY_DATA_DIR=./.llm-wiki-memory
# MEMORY_SETTINGS_PATH=./.llm-wiki-memory/settings/settings.yaml

# Identity: scopes recall so two installs don't cross-leak. Defaults to the
# workspace directory name when empty.
# MEMORY_DEFAULT_PROJECT_MODULE=
# LLM_WIKI_MEMORY_PROJECT=

# MCP server name advertised at initialize (deployment indirection).
# MEMORY_MCP_SERVER_NAME=llm-wiki-memory
