# llm-wiki-memory settings. Rendered to ./.llm-wiki-memory/settings/.env by
# bootstrap.sh — auto-detected at install (see bootstrap.sh `--provider` flag),
# user-editable thereafter. Lines are KEY=VALUE; process env overrides file
# values. To re-detect: re-run bootstrap.sh — it preserves any user-edited
# MEMORY_LLM_PROVIDER line (kept-existing log message confirms).

# LLM provider for atom extraction (flush), dedup decisions (compile), and
# consolidate's LLM passes (3A merge-near-duplicates, 3B semantic-refresh).
# One of:
#   claude              — uses the `claude` CLI on PATH (default for Claude Code)
#   codex               — uses the `codex` CLI on PATH
#   anthropic           — direct API; needs ANTHROPIC_API_KEY
#   openai              — direct API; needs OPENAI_API_KEY
#   openai-compatible   — local OpenAI-compatible endpoint (ollama, vLLM,
#                         lm-studio, llama.cpp server, litellm proxy); set
#                         MEMORY_LLM_BASE_URL (API key optional for local/RFC1918)
#   mock                — test/dev only; canned response from MEMORY_LLM_MOCK_*
MEMORY_LLM_PROVIDER=claude

# Provider-agnostic model override. When set, wins over ANTHROPIC_MODEL /
# OPENAI_MODEL. For openai-compatible, set this to whatever name your local
# server expects (e.g. "llama3.1:8b-instruct" for ollama).
# MEMORY_LLM_MODEL=

# OpenAI-compatible base URL (overrides https://api.openai.com/v1). When set
# to a localhost / RFC1918 host, OPENAI_API_KEY becomes optional. Examples:
#   MEMORY_LLM_BASE_URL=http://localhost:11434/v1   # ollama default
#   MEMORY_LLM_BASE_URL=http://localhost:8000/v1    # vLLM / lm-studio
# MEMORY_LLM_BASE_URL=

# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Mock provider (test-only). One of these MUST be set when PROVIDER=mock.
# MEMORY_LLM_MOCK_RESPONSE='{"action":"skip","reason":"mock"}'
# MEMORY_LLM_MOCK_FILE=/tmp/mock-llm-response.json

# Wiki + embedding locations (defaults are derived from the data dir).
# LLM_WIKI_MEMORY_ROOT=./.llm-wiki-memory/wiki
# MEMORY_EMBED_CACHE=./.llm-wiki-memory/index/embeddings.json

# Recall engine. Backend: transformers (bge-large, default) | lexical (no model).
# bge-large-en-v1.5 gives the best routing quality; first run downloads it once
# (~340MB quantized). For a much smaller download set a lighter model (e.g.
# Xenova/bge-small-en-v1.5, ~35MB); see the README model table for the options.
MEMORY_EMBED_BACKEND=transformers
MEMORY_EMBED_MODEL=Xenova/bge-large-en-v1.5
# MEMORY_EMBED_CACHE_DIR=./.llm-wiki-memory/index/models
MEMORY_RECALL_SCORE_THRESHOLD=0.0

# Pipeline routing (category names).
MEMORY_FLUSH_SLOT=daily
MEMORY_COMPILE_SLOT=knowledge

# Hook + flush thresholds.
MEMORY_HOOK_MAX_TURNS=30
MEMORY_HOOK_MAX_CHARS=80000
MEMORY_HOOK_SESSION_END_MIN_TURNS=1
MEMORY_HOOK_PRECOMPACT_MIN_TURNS=5

# Compile tuning.
MEMORY_COMPILE_SEARCH_LIMIT=5
MEMORY_ATOM_BODY_MAX_CHARS=700
MEMORY_COMPILE_QUALITY_STRICT=false
MEMORY_COMPILE_LOCK_STALE_MS=1800000

# ExitPlanMode auto-capture.
MEMORY_HOOK_EXITPLANMODE_DISABLE=false
MEMORY_HOOK_EXITPLANMODE_MAX_BYTES=256000

# Embedding-cache GC cadence (days) for `gc-embeddings --if-due` and the
# SessionEnd embed-gc hook. Default 7 (weekly). `0` or `off` disables it.
# Plain `gc-embeddings` (no --if-due) always runs regardless.
MEMORY_GC_INTERVAL_DAYS=7

# Consolidate orchestrator (search-driven AutoDream-style refinement of
# self_improvement + knowledge). All knobs have safe defaults; uncomment to
# override. The daily cron + hook-less skill rule call this with --if-due.
# MEMORY_CONSOLIDATE_INTERVAL_DAYS=1
# MEMORY_CONSOLIDATE_PASSES=all
# MEMORY_CONSOLIDATE_LLM_PASSES=on
# MEMORY_CONSOLIDATE_LLM_MAX_RETRIES=2
# MEMORY_CONSOLIDATE_REFRESH_MAX_PER_RUN=25
# MEMORY_CONSOLIDATE_COSINE_THRESHOLD=0.97
# MEMORY_CONSOLIDATE_COSINE_LEXICAL_THRESHOLD=0.995
# MEMORY_CONSOLIDATE_CLUSTER_TOP_K=12
# MEMORY_CONSOLIDATE_CLUSTER_SCORE_THRESHOLD=0.75
# MEMORY_CONSOLIDATE_ORPHAN_TTL_DAYS=365
# MEMORY_CONSOLIDATE_STALE_AFTER_MONTHS=6
# MEMORY_CONSOLIDATE_ARCHIVE_BODY_MAX=1200
# MEMORY_CONSOLIDATE_ARCHIVE_AGE_DAYS=30

# Recall-touch instrumentation: search/recall hits stamp memory.last_recalled_at
# and increment memory.recall_count on the returned leaves. Throttled per-leaf
# (default 24h). Set MEMORY_RECALL_TOUCH=off to disable entirely.
# MEMORY_RECALL_TOUCH=on
# MEMORY_RECALL_TOUCH_MIN_HOURS=24

# Write-gate for self_improvement (memory-write hardening). Default on:
# save_lesson and save_to_dataset(dataset="self_improvement") REQUIRE
# `userRequested:true` (set only when the user explicitly asked in this turn).
# Off disables the L3 server-side check (L1 discipline + L2 hook still apply).
# MEMORY_WRITE_GATE_SELF_IMPROVEMENT=on

# Identity: scopes recall so two installs don't cross-leak. Defaults to the
# workspace directory name when empty.
# MEMORY_DEFAULT_PROJECT_MODULE=
