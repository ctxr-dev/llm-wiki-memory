# llm-wiki-memory settings. Rendered to ./.llm-wiki-memory/settings/.env by
# bootstrap.sh. Lines are KEY=VALUE; process env overrides file values.

# LLM provider for atom extraction (flush) and dedup decisions (compile).
# One of: claude | codex | anthropic | openai
MEMORY_LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Wiki + embedding locations (defaults are derived from the data dir).
# LLM_WIKI_MEMORY_ROOT=./.llm-wiki-memory/wiki
# MEMORY_EMBED_CACHE=./.llm-wiki-memory/index/embeddings.json

# Recall engine. Backend: transformers (MiniLM, default) | lexical (no model).
MEMORY_EMBED_BACKEND=transformers
MEMORY_EMBED_MODEL=Xenova/all-MiniLM-L6-v2
# MEMORY_EMBED_CACHE_DIR=./.llm-wiki-memory/index/models
MEMORY_RECALL_SCORE_THRESHOLD=0.0

# Pipeline routing (category names).
MEMORY_FLUSH_SLOT=daily
MEMORY_COMPILE_SLOT=knowledge

# Hook + flush thresholds.
MEMORY_HOOK_MAX_TURNS=30
MEMORY_HOOK_MAX_CHARS=80000
MEMORY_HOOK_SESSION_END_MIN_TURNS=1
MEMORY_HOOK_PRECOMPACT_MIN_TURNS=5

# Compile tuning.
MEMORY_COMPILE_SEARCH_LIMIT=5
MEMORY_ATOM_BODY_MAX_CHARS=700
MEMORY_COMPILE_QUALITY_STRICT=false
MEMORY_COMPILE_LOCK_STALE_MS=1800000

# ExitPlanMode auto-capture.
MEMORY_HOOK_EXITPLANMODE_DISABLE=false
MEMORY_HOOK_EXITPLANMODE_MAX_BYTES=256000

# Identity: scopes recall so two installs don't cross-leak. Defaults to the
# workspace directory name when empty.
# MEMORY_DEFAULT_PROJECT_MODULE=
